# Cloudflare + Backblaze B2 环境变量
# 在 Cloudflare Pages 控制台 → Settings → Environment Variables 中配置

# JWT 密钥
TOKEN_SECRET=film-portfolio-secret-2024

# Backblaze B2 存储
B2_KEY_ID=你的B2_KeyID
B2_APPLICATION_KEY=你的B2_ApplicationKey
B2_BUCKET_NAME=video-website
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# 可选：如果通过 Cloudflare CDN 代理 B2 下载，填写自定义域名
# B2_DOWNLOAD_DOMAIN=https://files.yourdomain.com
